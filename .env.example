# Postgres
APP_NAME=skeleton
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_EXPOSED_PORT=5432
POSTGRES_DB=mcp_config
POSTGRES_USER=mcp_user
POSTGRES_PASSWORD=mcp_password

# Vault
VAULT_ADDR=http://127.0.0.1:8200
VAULT_EXPOSED_PORT=8200
VAULT_CLUSTER_EXPOSED_PORT=8201
VAULT_TOKEN=root
VAULT_AGENT_ENABLED=false
VAULT_AGENT_AUTH_MODE=file
VAULT_AGENT_TOKEN_FILE_PATH=/tmp/vault-agent-token
VAULT_AGENT_LISTENER_ENABLED=true
VAULT_AGENT_LISTENER_ADDR=http://127.0.0.1:8100
VAULT_UNSEAL_KEY=
VAULT_KV_MOUNT=secret
VAULT_WRITE_RETRY_ATTEMPTS=3
VAULT_WRITE_RETRY_BASE_DELAY_MS=200
VAULT_WRITE_RETRY_MAX_DELAY_MS=2000

# App
MCP_SERVER_NAME=skeleton-mcp
MCP_SERVER_VERSION=0.1.0
MCP_ALLOW_SENSITIVE_OUTPUT=false
MCP_ADMIN_AUTH_KEY=
MCP_TRANSPORT_MODE=stdio
MCP_CONFIG_DEFAULT_USER_ID=default
MCP_TOKEN_ROTATION_DEFAULT_INTERVAL_MS=86400000
MCP_TOKEN_ROTATION_USER_INTERVAL_CONFIG_KEY=token.rotation.intervalMs
MCP_VAULT_AGENT_AUTH_MODE_CONFIG_KEY=vault.agent.auth.mode
MCP_VAULT_AGENT_TOKEN_FILE_PATH_CONFIG_KEY=vault.agent.tokenFilePath
MCP_VAULT_AGENT_LISTENER_ADDR_CONFIG_KEY=vault.agent.listener.addr

# HTTP transport
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_HTTP_EXPOSED_PORT=3000
MCP_HTTP_PATH=/mcp
MCP_HTTP_HEALTH_PATH=/healthz
MCP_HTTP_AUTH_MODE=token
MCP_HTTP_TOKEN_SOURCE=vault
MCP_HTTP_AUTH_TOKENS=replace-me-token
MCP_HTTP_TRUST_PROXY=false
MCP_HTTP_ALLOWED_ORIGINS=
MCP_HTTP_ALLOWED_IPS=
MCP_HTTP_MAX_BODY_BYTES=1048576
MCP_HTTP_RATE_LIMIT_WINDOW_MS=60000
MCP_HTTP_RATE_LIMIT_MAX_REQUESTS=60
MCP_HTTP_VAULT_TOKEN_INDEX_PATH=skeleton/http/auth/token-index
MCP_HTTP_VAULT_TOKEN_DEFAULT_USER_ID=default
MCP_HTTP_VAULT_TOKEN_REQUIRED_SCOPES=
MCP_HTTP_VAULT_TOKEN_REQUIRED_AUDIENCE=
MCP_HTTP_VAULT_TOKEN_CACHE_TTL_MS=30000
MCP_HTTP_OAUTH2_INTROSPECTION_URL=
MCP_HTTP_OAUTH2_CLIENT_ID=
MCP_HTTP_OAUTH2_CLIENT_SECRET=
MCP_HTTP_OAUTH2_REQUIRED_SCOPES=
MCP_HTTP_OAUTH2_REQUIRED_AUDIENCE=
MCP_HTTP_OAUTH2_TIMEOUT_MS=5000
MCP_HTTP_OAUTH2_CACHE_TTL_MS=30000

# Reserved for direct TLS termination in Node.js (disabled when using proxy TLS)
MCP_HTTP_TLS_ENABLED=false
MCP_HTTP_TLS_CERT_PATH=
MCP_HTTP_TLS_KEY_PATH=
