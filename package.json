{
  "name": "skeleton-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js MCP skeleton with Vault secrets and Postgres configuration storage",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npm run start:stdio",
    "start:stdio": "node src/index.js",
    "start:http": "node src/http/index.js",
    "start:both": "node src/start-both.js",
    "test": "node --test tests/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "dotenv": "^16.6.1",
    "node-vault": "^0.10.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  }
}
