{
  "name": "skeleton-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Skeleton MCP server for integrating target service APIs",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "npm run start:stdio",
    "start:stdio": "node src/index.js",
    "start:http": "node src/http/index.js",
    "start:both": "node src/start-both.js",
    "vault:unseal-key": "node scripts/vault-unseal-key.js",
    "vault:seed-http-token": "node scripts/vault-seed-http-token.js",
    "vault:seed-oauth-token": "node scripts/vault-seed-oauth-token.js",
    "test": "node --test tests/**/*.test.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.1",
    "dotenv": "^16.6.1",
    "node-vault": "^0.10.0",
    "pg": "^8.16.3",
    "zod": "^3.25.76"
  }
}
